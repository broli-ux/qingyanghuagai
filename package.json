{
  "name": "vue-cli-dynamic-blog",
  "version": "1.0.0",
  "private": true,
  "description": "一个基于 Vue CLI + Vue 3 的动态个人博客模板，适合部署到 GitHub Pages。",
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "@vue/cli-service": "^5.0.8",
    "core-js": "^3.38.1",
    "marked": "^18.0.5",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "gh-pages": "^6.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
